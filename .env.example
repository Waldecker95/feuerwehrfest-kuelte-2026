# Supabase – neue Projekt-Credentials aus dem Supabase Dashboard eintragen
VITE_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key

# Für Netlify: Diese Variablen unter Site Settings > Environment Variables eintragen
# Für lokale Entwicklung: Diese Datei als .env.local kopieren und befüllen
